# Modele de configuration. Sur le Raspberry, copie-le puis renseigne tes valeurs :
#   cp poolalert.env.example poolalert.env
#   nano poolalert.env
# (le vrai poolalert.env est ignore par git)
TELEGRAM_BOT_TOKEN=colle_ton_token_ici
TELEGRAM_CHAT_ID=colle_ton_chat_id_ici

# Deuxieme compte Telegram : recoit uniquement les alertes du wallet
# 0xC5E0bBFb5A0bAE8c4aF604E31F32729F63c20129.
# - Renseigne au minimum TELEGRAM_CHAT_ID_2 (le chat_id de l'autre compte).
# - TELEGRAM_BOT_TOKEN_2 est optionnel : laisse-le vide pour reutiliser le meme bot
#   (l'autre compte doit alors avoir demarre une conversation avec ce bot), ou colle
#   le token d'un bot separe.
# TELEGRAM_BOT_TOKEN_2=colle_le_token_du_2e_bot_ici
# TELEGRAM_CHAT_ID_2=colle_le_chat_id_du_2e_compte_ici

# Seuil d'alerte anticipee (fraction de la largeur du range, defaut 0.05 = 5%).
# Sur un range etroit (60 ticks), 0.05 ne laisse que 3 ticks de marge : monte a 0.2.
# Decommente pour surcharger :
# WARN_MARGIN_PCT=0.2

# Noeud HyperEVM utilise. Le RPC public rate-limite : decommente pour en changer.
# RPC_URL=https://rpc.hyperliquid.xyz/evm

# Silence entre deux passages de l'alarme sonore, en millisecondes (defaut 60000 = 1 min).
# Le son dure ~4 s : une valeur trop basse donne une alarme quasi continue.
# ALARM_INTERVAL_MS=120000

# Lecteur audio. Par defaut aplay (seul a lire nativement alarm.wav, un WAV 24 bits).
# Ne pas mettre mpg123 : il prend le WAV pour du MPEG et ne se termine jamais.
# AUDIO_PLAYER=aplay
